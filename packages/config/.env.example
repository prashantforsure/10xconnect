# Copy to a `.env` at the repo root and fill in as later steps require.
# All variables are OPTIONAL in Step 1 (validated by packages/config via zod).

# Runtime
NODE_ENV=development

# Transport adapter: 'mock' (in-memory, default for dev/test) | 'unipile' (real).
ADAPTER=mock

# Supabase (Step 2+)
# Server-side (used by apps/api and web server components).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-only secrets. NEVER expose these to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Project JWT secret (Supabase dashboard -> Settings -> API -> JWT Secret).
# The API verifies access tokens (HS256) with this.
SUPABASE_JWT_SECRET=

# Web (browser) — exposed to the client by Next.js, so anon key only.
# Mirror SUPABASE_URL / SUPABASE_ANON_KEY here for apps/web.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Base URL used to build auth email + OAuth redirect links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Base URL of the NestJS API (used by the web typed API client).
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
# Chrome Web Store listing URL for the LinkedIn-connector extension (apps/extension).
# Set once the listing is published; the in-app "Add to Chrome" button links here.
NEXT_PUBLIC_EXTENSION_STORE_URL=
# Show the manual "Paste li_at" connect option (testing). Always on in development;
# set to "true" to also expose it on a deployed/preview env. Off in production.
NEXT_PUBLIC_ALLOW_MANUAL_CONNECT=

# Google OAuth: the Client ID + Secret are configured in the Supabase dashboard
# (Authentication -> Providers -> Google), not here. Add the callback URL
# {NEXT_PUBLIC_SITE_URL}/auth/callback to Supabase Auth -> URL Configuration.

# Database (Step 3+)
DATABASE_URL=

# Redis / queue (Phase 4+)
REDIS_URL=

# Transport: Unipile (Phase 2+)
UNIPILE_API_KEY=
UNIPILE_DSN=

# AI personalization (Phase 6+)
LLM_API_KEY=

# Voice notes / TTS (Phase 6+)
TTS_API_KEY=

# Payments (Phase 9+)
CREEM_API_KEY=

# Developer access. Emails here (comma / space / semicolon separated) get FULL
# access — unlimited sending-account slots + an always-active ($0) subscription —
# in any workspace they OWN, in every environment including production. Scoped to
# the workspace owner's email, so real customers are unaffected. A built-in
# default (see DEFAULT_DEVELOPER_EMAILS in packages/config) is always included, so
# this env var is only needed to add MORE developer emails.
DEVELOPER_EMAILS=

# Observability (Phase 12+)
SENTRY_DSN=

# App
APP_URL=http://localhost:3000
# The API's own PUBLICLY reachable base URL (no trailing /api/v1). Used to build
# the Unipile Hosted Auth notify_url, which Unipile must reach — set to a public
# URL in production. localhost only works with ADAPTER=mock (callback simulated).
API_PUBLIC_URL=http://localhost:3001
