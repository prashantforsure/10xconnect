# Copy to a `.env` at the repo root and fill in as later steps require.
# All variables are OPTIONAL in Step 1 (validated by packages/config via zod).

# Runtime
NODE_ENV=development

# Supabase (Step 2+)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Step 3+)
DATABASE_URL=

# Redis / queue (Phase 4+)
REDIS_URL=

# Transport: Unipile (Phase 2+)
UNIPILE_API_KEY=
UNIPILE_DSN=

# AI personalization (Phase 6+)
LLM_API_KEY=

# Voice notes / TTS (Phase 6+)
TTS_API_KEY=

# Payments (Phase 9+)
CREEM_API_KEY=

# Observability (Phase 12+)
SENTRY_DSN=

# App
APP_URL=http://localhost:3000
