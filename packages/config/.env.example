# Copy to a `.env` at the repo root and fill in as later steps require.
# All variables are OPTIONAL in Step 1 (validated by packages/config via zod).

# Runtime
NODE_ENV=development

# Transport adapter: 'mock' (in-memory, default for dev/test) | 'unipile' (real).
ADAPTER=mock

# Supabase (Step 2+)
# Server-side (used by apps/api and web server components).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-only secrets. NEVER expose these to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Project JWT secret (Supabase dashboard -> Settings -> API -> JWT Secret).
# The API verifies access tokens (HS256) with this.
SUPABASE_JWT_SECRET=

# Web (browser) — exposed to the client by Next.js, so anon key only.
# Mirror SUPABASE_URL / SUPABASE_ANON_KEY here for apps/web.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Base URL used to build auth email + OAuth redirect links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Base URL of the NestJS API (used by the web typed API client).
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Google OAuth: the Client ID + Secret are configured in the Supabase dashboard
# (Authentication -> Providers -> Google), not here. Add the callback URL
# {NEXT_PUBLIC_SITE_URL}/auth/callback to Supabase Auth -> URL Configuration.

# Database (Step 3+)
DATABASE_URL=

# Redis / queue (Phase 4+)
REDIS_URL=

# Transport: Unipile (Phase 2+)
UNIPILE_API_KEY=
UNIPILE_DSN=

# AI personalization (Phase 6+)
LLM_API_KEY=

# Voice notes / TTS (Phase 6+)
TTS_API_KEY=

# Payments (Phase 9+)
CREEM_API_KEY=

# Observability (Phase 12+)
SENTRY_DSN=

# App
APP_URL=http://localhost:3000
