# 10xConnect environment — repo-root template.
#
# Copy this to `.env` at the repo root and fill in the values. The real `.env` is
# git-ignored (see .gitignore); THIS file is committed, so it must NEVER contain a
# real secret — placeholders only. Loaded automatically by apps/api, apps/worker
# (via packages/config) and apps/web (via next.config.ts); all vars are validated
# with zod at boot (packages/config).

# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------
NODE_ENV=development

# ----------------------------------------------------------------------------
# Supabase — REQUIRED for auth + data. Dashboard -> Project Settings -> API.
# ----------------------------------------------------------------------------
# Server-side (apps/api, apps/worker, web server components).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-only secrets. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Settings -> API -> JWT Secret (legacy HS256). The API verifies access tokens with this.
SUPABASE_JWT_SECRET=
# Server-only. AES-256-GCM key for encrypting sending-account credentials at rest
# (Infinite login). 32 bytes, hex (64 chars) or base64. Rotating it makes existing
# encrypted rows undecryptable. Generate: `openssl rand -hex 32`.
SECRETS_ENCRYPTION_KEY=

# Browser (Next.js inlines these). Mirror the URL + anon key above — anon key only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Base URL used to build auth email + OAuth redirect links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Base URL of the NestJS API (used by the web typed API client).
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
# Chrome Web Store listing URL for the LinkedIn-connector extension (apps/extension).
NEXT_PUBLIC_EXTENSION_STORE_URL=
# Show the manual "Paste li_at" connect option (testing). Always on in development;
# set "true" to also expose it on a deployed/preview env. Off in production.
NEXT_PUBLIC_ALLOW_MANUAL_CONNECT=

# Google OAuth: the Client ID + Secret live in the Supabase dashboard
# (Authentication -> Providers -> Google), NOT here. Add the callback URL
# {NEXT_PUBLIC_SITE_URL}/auth/callback to Supabase Auth -> URL Configuration.

# ----------------------------------------------------------------------------
# Database
#   Migrations / SET ROLE scripts: session pooler, port 5432.
#   App + worker pooled runtime:   transaction pooler, port 6543.
# ----------------------------------------------------------------------------
DATABASE_URL=

# Redis / queue (BullMQ swap seam; optional for the MVP — the DB is the queue).
REDIS_URL=

# ----------------------------------------------------------------------------
# Transport adapter selection
#   mock    = in-memory adapter (default) — NO real LinkedIn calls. Use for dev/demos.
#   unipile = real LinkedIn transport via Unipile — REAL sends. Pair with
#             DISPATCH_MODE=production + DISPATCH_ENABLED gating below.
# ----------------------------------------------------------------------------
ADAPTER=mock
# Transport: Unipile (only needed when ADAPTER=unipile).
UNIPILE_API_KEY=
UNIPILE_DSN=

# ----------------------------------------------------------------------------
# Dispatch engine cadence (the orchestration "brain" — account safety pacing).
# ----------------------------------------------------------------------------
# Master on/off for the worker's dispatch loop. Set false to connect ADAPTER=unipile
# WITHOUT sending anything real yet (relink accounts, inspect the queue).
DISPATCH_ENABLED=true
# How often the worker polls for due actions (ms). Not the send spacing.
DISPATCH_TICK_MS=15000
# Spacing PRESET:
#   testing    (default) = ~1s spacing, ignores working hours — MOCK demos/dev only.
#   production           = human 4–8 min jittered spacing within working hours.
# Flip to production for any real LinkedIn account.
DISPATCH_MODE=testing
# Optional per-field overrides (ms) — tune a preset without leaving the mode.
# Recommended safe pacing for real sends: a ~15-minute gap between sends per account.
#   DISPATCH_MIN_SPACING_MS=900000   # 15-min floor
#   DISPATCH_JITTER_MS=300000        # + up to 5 min random => 15–20 min apart
DISPATCH_MIN_SPACING_MS=
DISPATCH_JITTER_MS=
# Set true to bypass the working-hours window (dev only; never in production).
DISPATCH_IGNORE_WORKING_HOURS=
# AI auto-reply humanizing delay. When the AI auto-sends a reply (autonomy dial,
# no human in the loop) it waits MIN + up to JITTER of random slack so it doesn't
# fire back instantly like a bot. Human-approved replies always send immediately.
# Unset => the DISPATCH_MODE preset (testing = 0 = instant; production = 5–10 min).
#   AI_AUTO_REPLY_MIN_DELAY_MS=300000  # 5-min floor
#   AI_AUTO_REPLY_JITTER_MS=300000     # + up to 5 min => 5–10 min
AI_AUTO_REPLY_MIN_DELAY_MS=
AI_AUTO_REPLY_JITTER_MS=

# ----------------------------------------------------------------------------
# AI personalization + conversation brain (LLM). Set LLM_PROVIDER=mock for a
# deterministic offline model that works with no key/quota.
# ----------------------------------------------------------------------------
LLM_API_KEY=
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
# Embeddings (conversation-brain RAG). EMBEDDING_API_KEY falls back to LLM_API_KEY.
EMBEDDING_API_KEY=
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001

# ----------------------------------------------------------------------------
# Voice notes / TTS (per-prospect cloned voice notes). Mock-safe by default.
# VOICE_API_KEY falls back to TTS_API_KEY.
# ----------------------------------------------------------------------------
TTS_API_KEY=
VOICE_API_KEY=
VOICE_PROVIDER=mock
VOICE_MODEL=eleven_multilingual_v2

# ----------------------------------------------------------------------------
# Accounts / access
# ----------------------------------------------------------------------------
# Bypass the billing slot cap on connected accounts (dev / self-host).
ALLOW_UNLIMITED_ACCOUNTS=false
# Developer-access allowlist (comma/space/semicolon separated). These emails get
# unlimited slots + an always-active ($0) subscription in workspaces they OWN, in
# every environment. A built-in default already covers the primary developer.
DEVELOPER_EMAILS=

# ----------------------------------------------------------------------------
# Webhooks / integrations
# ----------------------------------------------------------------------------
# Shared secret for INBOUND provider webhooks (Unipile notify_url, payments). When
# set, webhook routes require it (x-webhook-secret header or ?secret=…) and fail
# closed. Leave blank for dev / the mock adapter.
WEBHOOK_SECRET=
# Outbound webhook/Slack delivery poller (apps/api).
INTEGRATIONS_DELIVERY_ENABLED=true
INTEGRATIONS_DELIVERY_TICK_MS=15000

# ----------------------------------------------------------------------------
# Payments (MoR) — optional until billing is live.
# ----------------------------------------------------------------------------
CREEM_API_KEY=

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
SENTRY_DSN=

# ----------------------------------------------------------------------------
# App URLs
# ----------------------------------------------------------------------------
APP_URL=http://localhost:3000
# The API's own PUBLICLY reachable base URL (no trailing /api/v1). Used to build
# the Unipile Hosted Auth notify_url, which Unipile must reach — set to a public
# URL in production. localhost only works with ADAPTER=mock (callback simulated).
API_PUBLIC_URL=http://localhost:3001
