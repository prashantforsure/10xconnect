{
  "manifest_version": 3,
  "name": "10xConnect — LinkedIn Connector",
  "version": "0.1.0",
  "description": "Securely connect your LinkedIn account to 10xConnect using your real, signed-in session — no password required.",
  "permissions": ["cookies"],
  "host_permissions": ["https://*.linkedin.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "10xConnect",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*", "https://app.10xconnect.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
